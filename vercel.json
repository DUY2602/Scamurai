{
  "buildCommand": "npm install --prefix Scamurai/frontend && npm run build --prefix Scamurai/frontend",
  "outputDirectory": "Scamurai/frontend/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
