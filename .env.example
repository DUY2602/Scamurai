# Copy this file to .env.local and replace the values below for local development.

# Frontend -> backend URL for local dev
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend CORS
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Supabase persistence
# When these are set, backend writes detection logs to Supabase
# and dashboard stats will be read from the Supabase table.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_TABLE=detection_results
